# =============================================================================
# SPRINT 1 SECURITY - Environment Variables Configuration
# =============================================================================
# Copy this file to .env.security and fill in your values.
# NEVER commit .env.security to version control!
# =============================================================================

# =============================================================================
# SECRETS MANAGEMENT
# =============================================================================

# Master key for encrypting secrets file (REQUIRED - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
TRADING_BOT_SECRET_KEY=your_master_key_here_minimum_32_characters

# HashiCorp Vault (optional - for production)
VAULT_ADDR=https://vault.example.com:8200
VAULT_TOKEN=hvs.your_vault_token_here
VAULT_NAMESPACE=trading

# =============================================================================
# HMAC KEY MANAGEMENT
# =============================================================================

# Master key for HMAC key encryption (REQUIRED - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
HMAC_MASTER_KEY=your_hmac_master_key_here_minimum_32_chars

# Storage backend: encrypted_file, vault, environment
HMAC_STORAGE_BACKEND=encrypted_file
HMAC_KEY_FILE=.hmac_keys.enc

# =============================================================================
# MT5 TRADING CREDENTIALS
# =============================================================================

MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Server

# =============================================================================
# ALERTING - PAGERDUTY
# =============================================================================

# Get this from PagerDuty: Services > Your Service > Integrations > Events API V2
PAGERDUTY_ROUTING_KEY=your_pagerduty_routing_key

# =============================================================================
# ALERTING - SLACK
# =============================================================================

# Create incoming webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# =============================================================================
# ALERTING - EMAIL (SMTP)
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_FROM=trading-bot@yourdomain.com
ALERT_EMAIL_TO=oncall@yourdomain.com,backup@yourdomain.com

# =============================================================================
# ALERTING - SMS (TWILIO)
# =============================================================================

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567
SMS_TO_NUMBERS=+15559876543,+15551112222

# =============================================================================
# DEAD MAN'S SWITCH
# =============================================================================

# Backend: http_webhook, redis, file
HEARTBEAT_BACKEND=http_webhook

# Timing (seconds)
HEARTBEAT_INTERVAL=30
HEARTBEAT_TIMEOUT=60

# HTTP Webhook backend (use services like Uptime Robot, Healthchecks.io, or custom)
HEARTBEAT_WEBHOOK_URL=https://hc-ping.com/your-uuid-here

# Redis backend (for distributed setups)
REDIS_URL=redis://localhost:6379/0

# Bot identification
BOT_ID=trading-bot-prod-1
ENVIRONMENT=production

# Emergency closure webhook (called when bot is detected as dead)
EMERGENCY_WEBHOOK_URL=https://your-backup-server.com/emergency-close

# =============================================================================
# SIEM INTEGRATION
# =============================================================================

# Backend: splunk, elasticsearch, cloudwatch, syslog, webhook, file
SIEM_BACKEND=file
SIEM_FILE_PATH=security_events.jsonl

# Splunk HEC
SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector
SPLUNK_HEC_TOKEN=your_hec_token

# Elasticsearch
ELASTICSEARCH_URL=https://elasticsearch.example.com:9200
ELASTICSEARCH_API_KEY=your_api_key

# AWS CloudWatch
AWS_REGION=us-east-1
CLOUDWATCH_LOG_GROUP=/trading-bot/security

# Syslog
SYSLOG_HOST=localhost
SYSLOG_PORT=514

# =============================================================================
# FEATURE FLAGS
# =============================================================================

ENABLE_SECRETS_MANAGER=true
ENABLE_HMAC_MANAGER=true
ENABLE_ALERT_MANAGER=true
ENABLE_DEAD_MAN_SWITCH=true
ENABLE_SIEM=true
