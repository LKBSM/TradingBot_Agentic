# =============================================================================
# TRADING BOT ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values.
#
# SECURITY WARNING: Never commit .env to version control!
# Add .env to your .gitignore file.
# =============================================================================

# =============================================================================
# METATRADER 5 CREDENTIALS (Required for live trading)
# =============================================================================
# Your MT5 broker account credentials
# Get these from your broker's client portal

MT5_LOGIN=12345678
MT5_PASSWORD=your_secure_password_here
MT5_SERVER=YourBroker-Server

# =============================================================================
# SECRETS ENCRYPTION (Required for encrypted secrets file)
# =============================================================================
# Encryption key for local secrets storage
# MUST be at least 32 characters for security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

TRADING_BOT_SECRET_KEY=your_32_plus_character_secret_key_here

# Optional: Pepper for additional security layer
# If set, adds extra protection to encrypted secrets
TRADING_BOT_PEPPER=optional_pepper_value

# =============================================================================
# KILL SWITCH ADMIN KEY (Required for emergency overrides)
# =============================================================================
# Admin key for force-resetting the kill switch
# MUST be at least 32 characters for security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

KILL_SWITCH_ADMIN_KEY=your_64_hex_character_admin_key_here

# =============================================================================
# HASHICORP VAULT (Optional - for enterprise deployment)
# =============================================================================
# If using HashiCorp Vault for secrets management

# VAULT_ADDR=https://vault.yourcompany.com:8200
# VAULT_TOKEN=your_vault_token
# VAULT_NAMESPACE=trading

# =============================================================================
# ALERTING & NOTIFICATIONS (Optional)
# =============================================================================
# Configure alerts for trading events

# Email notifications
ALERT_EMAIL=your_email@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Discord webhook (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Slack webhook (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# PagerDuty (optional - for critical alerts)
# PAGERDUTY_API_KEY=your_pagerduty_key
# PAGERDUTY_ROUTING_KEY=your_routing_key

# =============================================================================
# DATA SOURCES (Optional - for enhanced analysis)
# =============================================================================

# Twitter/X API (for sentiment analysis)
# TWITTER_API_KEY=your_twitter_api_key
# TWITTER_API_SECRET=your_twitter_api_secret
# TWITTER_ACCESS_TOKEN=your_access_token
# TWITTER_ACCESS_SECRET=your_access_secret

# News API
# NEWS_API_KEY=your_newsapi_key

# Alpha Vantage (for additional market data)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Twelve Data (XAU + EURUSD OHLCV — MIA Markets V1 backend, Chantier 1)
# Free tier: 8 req/min, 800 req/day. Sign up at https://twelvedata.com
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# =============================================================================
# MIA MARKETS V2 — MARKET READING RUNTIME (Chantier 3)
# =============================================================================
# When BOOTSTRAP_ENABLED=true, the FastAPI lifespan builds the
# MarketReadingAssembler at startup (so GET /api/market-reading returns 200
# instead of 503) and, if SCHEDULER_ENABLED=true, starts the hybrid-mode
# recurring scheduler. Both default OFF when unset so tests/dev stay light.
# Bootstrap requires ANTHROPIC_API_KEY and TWELVE_DATA_API_KEY to be set —
# missing either raises BootstrapConfigurationError (fail-fast, not silent).
BOOTSTRAP_ENABLED=true

# Hybrid scheduler — recurring regeneration of active (instrument, timeframe)
SCHEDULER_ENABLED=true
SCHEDULER_TICK_INTERVAL_SECONDS=60
SCHEDULER_AUTO_STOP_HOURS=24

# News pipeline (ForexFactory) — when true the assembler fills events.news_*
NEWS_PIPELINE_ENABLED=true
NEWS_CACHE_DB_PATH=./data/news_cache.db

# Indicator-grade context windows (widened 2026-06-15). All optional — the code
# defaults already apply these values; set them only to tune.
#   MARKET_READING_LOOKBACK  candles fetched per reading (zones + regime + chart)
#   NEWS_LOOKAHEAD_MIN       upcoming-news window in minutes (4320 = 3 days)
#   NEWS_LOOKBACK_MIN        recently-published window in minutes (1440 = 24h)
#   MAX_ZONES_PER_TYPE       max OB (and max FVG) zones surfaced per reading
MARKET_READING_LOOKBACK=500
NEWS_LOOKAHEAD_MIN=4320
NEWS_LOOKBACK_MIN=1440
MAX_ZONES_PER_TYPE=12

# Chatbot niveau 1.5 strict (Chantier 4) — when CHATBOT_ENABLED=true the lifespan
# builds the Chatbot at startup (so POST /api/chatbot/message returns 200 instead
# of 503). Requires the MarketReadingAssembler bootstrapped first (BOOTSTRAP_ENABLED)
# and ANTHROPIC_API_KEY set. Default OFF so tests/dev stay light.
CHATBOT_ENABLED=false

# Live-tick zone interaction (PROTOTYPE — dev / free tier). When
# LIVE_TICK_ENABLED=true the lifespan opens ONE shared Twelve Data WebSocket
# (/quotes/price) and exposes GET /api/live-price (SSE) so the app can update
# zone INTERACTION (FVG fill, OB touch) intra-candle. Default OFF — the app
# refreshes zones only at candle close, unchanged. Requires TWELVE_DATA_API_KEY.
# DETECTION and BOS/CHOCH are NEVER affected by the tick (SMC law: close only).
# NOTE: Twelve Data WebSocket is officially Pro/Business; the trial allows ONE
# connection (test only). A commercial launch requires the Business plan.
LIVE_TICK_ENABLED=false
# Comma-separated instruments to stream (default: XAUUSD,EURUSD). 2 symbols = 2
# of the 8 trial WS credits.
# LIVE_TICK_INSTRUMENTS=XAUUSD,EURUSD

# =============================================================================
# MONITORING & OBSERVABILITY (Optional)
# =============================================================================

# Weights & Biases (for training monitoring)
# WANDB_API_KEY=your_wandb_api_key
# WANDB_ENTITY=your_username
# WANDB_PROJECT=trading_bot

# Prometheus metrics endpoint
# PROMETHEUS_PORT=9090

# =============================================================================
# DATABASE CONFIGURATION (Optional - defaults work for most cases)
# =============================================================================

# SQLite database paths (defaults to ./data/)
# KILL_SWITCH_DB_PATH=./data/kill_switch.db
# AUDIT_LOG_DB_PATH=./data/audit_log.db

# =============================================================================
# ENVIRONMENT FLAGS
# =============================================================================

# Set to 'production' for stricter validation
# TRADING_ENV=development

# Enable debug logging (set to 'true' for verbose output)
# DEBUG=false

# =============================================================================
# NOTES:
# =============================================================================
#
# 1. For security, use strong random values:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 2. Never share your .env file or commit it to git
#
# 3. In production, consider using:
#    - HashiCorp Vault for secrets management
#    - Environment variables injected by your deployment platform
#    - AWS Secrets Manager / Azure Key Vault / GCP Secret Manager
#
# 4. Rotate credentials regularly (every 90 days recommended)
#
# =============================================================================
