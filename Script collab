class RobustTrainingCallback(BaseCallback):
    """
    Training callback with:
    - Step-limited evaluation (prevents freezing)
    - Manual progress tracking (no tqdm interference)
    - Heartbeat output to confirm training is alive
    - Error handling
    """

    def __init__(self, eval_env, eval_freq, patience, min_steps_before_stopping, max_eval_steps, total_timesteps):
        super().__init__()
        self.eval_env = eval_env
        self.eval_freq = eval_freq
        self.patience = patience
        self.min_steps_before_stopping = min_steps_before_stopping
        self.max_eval_steps = max_eval_steps
        self.total_timesteps = total_timesteps

        self.best_sharpe = -np.inf
        self.no_improve = 0
        self.results = []
        self.eval_count = 0
        self.start_time = None
        self.last_heartbeat = 0
        self.heartbeat_freq = 10000  # Print heartbeat every 10K steps

        print(f"  Callback config:")
        print(f"    Eval frequency: {eval_freq:,} steps")
        print(f"    Early stop patience: {patience}")
        print(f"    Min steps before stop: {min_steps_before_stopping:,}")
        print(f"    Max eval steps: {max_eval_steps}")
        print(f"    Heartbeat frequency: {self.heartbeat_freq:,} steps")
        sys.stdout.flush()

    def _on_training_start(self):
        """Called when training starts."""
        self.start_time = time.time()
        print(f"\n📍 Training started at step 0")
        sys.stdout.flush()

    def _on_step(self):
        # Initialize start time if not set
        if self.start_time is None:
            self.start_time = time.time()

        # ===== HEARTBEAT - Print progress every 10K steps =====
        if self.n_calls - self.last_heartbeat >= self.heartbeat_freq:
            self.last_heartbeat = self.n_calls
            elapsed = time.time() - self.start_time
            progress = self.n_calls / self.total_timesteps * 100
            speed = self.n_calls / elapsed if elapsed > 0 else 0
            remaining = (self.total_timesteps - self.n_calls) / speed if speed > 0 else 0

            print(f"📍 Step {self.n_calls:,}/{self.total_timesteps:,} ({progress:.1f}%) | "
                  f"Speed: {speed:.0f} steps/s | "
                  f"Elapsed: {elapsed/60:.1f}min | "
                  f"Remaining: {remaining/60:.1f}min")
            sys.stdout.flush()

        # ===== EVALUATION - Every eval_freq steps =====
        if self.n_calls % self.eval_freq != 0:
            return True

        self.eval_count += 1

        print(f"\n{'='*60}")
        print(f"[EVAL #{self.eval_count}] Step {self.n_calls:,}")
        print(f"{'='*60}")
        sys.stdout.flush()

        try:
            # Run evaluation with step limit
            print(f"  Running evaluation ({self.max_eval_steps} steps max)...")
            sys.stdout.flush()

            start_time = time.time()
            metrics = self._safe_evaluate()
            eval_time = time.time() - start_time

            self.results.append({'step': self.n_calls, **metrics})

            print(f"  Completed in {eval_time:.1f}s")
            print(f"  Results:")
            print(f"    Sharpe:   {metrics['sharpe']:>8.2f}")
            print(f"    MaxDD:    {metrics['max_dd']:>8.1%}")
            print(f"    WinRate:  {metrics['win_rate']:>8.1%}")
            print(f"    Trades:   {metrics['trades']:>8}")
            sys.stdout.flush()

            # Check for improvement
            if metrics['sharpe'] > self.best_sharpe + 0.01:
                self.best_sharpe = metrics['sharpe']
                self.no_improve = 0
                self.model.save('models/best_model')
                print(f"  ⭐ NEW BEST! Sharpe: {self.best_sharpe:.2f}")
            else:
                self.no_improve += 1
                print(f"  No improvement ({self.no_improve}/{self.patience})")

            print(f"{'='*60}\n")
            sys.stdout.flush()

            # Early stopping check
            if self.n_calls >= self.min_steps_before_stopping:
                if self.no_improve >= self.patience:
                    print(f"\n🛑 Early stopping at step {self.n_calls:,}")
                    print(f"   No improvement for {self.patience} evaluations")
                    sys.stdout.flush()
                    return False

        except Exception as e:
            print(f"  ❌ EVALUATION ERROR: {e}")
            import traceback
            traceback.print_exc()
            sys.stdout.flush()
            # Continue training even if evaluation fails

        return True

    def _safe_evaluate(self):
        """
        Safe evaluation with step limit and error handling.
        """
        try:
            obs, _ = self.eval_env.reset()
        except Exception as e:
            print(f"[EVAL] Reset failed: {e}")
            return {'sharpe': 0, 'max_dd': 1.0, 'total_return': 0, 'win_rate': 0, 'trades': 0}

        done = False
        pv = [config.initial_balance]
        steps = 0

        while not done and steps < self.max_eval_steps:
            try:
                action, _ = self.model.predict(obs, deterministic=True)
                obs, _, done, _, info = self.eval_env.step(action)
                pv.append(config.initial_balance + info['total_pnl'])
                steps += 1
            except Exception as e:
                print(f"[EVAL] Step {steps} failed: {e}")
                break

        # Calculate metrics
        pv = np.array(pv)

        if len(pv) < 2:
            return {'sharpe': 0, 'max_dd': 1.0, 'total_return': 0, 'win_rate': 0, 'trades': 0}

        rets = np.diff(pv) / (pv[:-1] + 1e-8)

        # Sharpe ratio (annualized for 15-min bars)
        if np.std(rets) > 1e-8:
            sharpe = float(np.mean(rets) / np.std(rets) * np.sqrt(252 * 24 * 4))
        else:
            sharpe = 0.0

        # Max drawdown
        peak = np.maximum.accumulate(pv)
        dd = (peak - pv) / (peak + 1e-8)
        max_dd = float(np.max(dd))

        # Total return
        total_return = float((pv[-1] / pv[0]) - 1)

        # Win rate and trades from last info
        win_rate = info.get('win_rate', 0) if info else 0
        trades = info.get('trade_count', 0) if info else 0

        return {
            'sharpe': sharpe,
            'max_dd': max_dd,
            'total_return': total_return,
            'win_rate': win_rate,
            'trades': trades,
            'eval_steps': steps
        }

