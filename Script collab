class SimpleTradingEnv(gym.Env):
    """
    Simplified, robust trading environment.

    Key features:
    - Guaranteed termination (max_steps limit)
    - Safe array indexing
    - NaN/Inf protection
    - Clear done conditions
    """

    def __init__(self, df, config, training=True, max_steps=None):
        super().__init__()
        self.config = config
        self.training = training
        self._prepare_data(df)

        # CRITICAL: Set max_steps to prevent infinite loops
        self.max_steps = max_steps if max_steps else len(self.prices) - 1

        # Spaces
        self.action_space = spaces.Discrete(3)  # 0=Hold, 1=Buy, 2=Sell
        self.observation_space = spaces.Box(
            low=-10.0, high=10.0,
            shape=(self.n_features,),
            dtype=np.float32
        )

        if DEBUG_MODE:
            print(f"    [ENV] Created: {len(self.prices)} bars, {self.n_features} features, max_steps={self.max_steps}")

        self.reset()

    def _prepare_data(self, df):
        """Prepare features - with safety checks."""
        df = df.copy()

        # Basic features
        df['returns'] = df['Close'].pct_change().fillna(0)
        df['rsi'] = ta.momentum.RSIIndicator(df['Close'], window=14).rsi().fillna(50)
        df['rsi_norm'] = (df['rsi'] - 50) / 50

        macd = ta.trend.MACD(df['Close'])
        df['macd'] = macd.macd().fillna(0)
        df['macd_signal'] = macd.macd_signal().fillna(0)
        df['macd_diff'] = (df['macd'] - df['macd_signal']).fillna(0)

        df['sma_20'] = df['Close'].rolling(20).mean().fillna(df['Close'])
        df['sma_50'] = df['Close'].rolling(50).mean().fillna(df['Close'])
        df['sma_ratio'] = ((df['Close'] / df['sma_20']) - 1).fillna(0)

        df['volatility'] = df['returns'].rolling(20).std().fillna(0.01) * np.sqrt(252)
        df['momentum'] = df['Close'].pct_change(10).fillna(0)

        if 'news_event' not in df.columns:
            df['news_event'] = 0
            df['news_surprise'] = 0

        # Feature columns
        feature_cols = ['returns', 'rsi_norm', 'macd_diff', 'sma_ratio',
                        'volatility', 'momentum', 'news_event', 'news_surprise']

        # Build features array
        features = df[feature_cols].values.astype(np.float32)

        # CRITICAL: Replace NaN/Inf with 0
        features = np.nan_to_num(features, nan=0.0, posinf=0.0, neginf=0.0)

        # Standardize
        self.scaler = StandardScaler()
        self.features = self.scaler.fit_transform(features)

        # Clip extreme values
        self.features = np.clip(self.features, -5.0, 5.0).astype(np.float32)

        # Price data
        self.prices = df['Close'].values.astype(np.float64)
        self.news = df['news_event'].values.astype(np.int32)

        # Dimensions
        self.n_bars = len(self.prices)
        self.n_features = len(feature_cols) + 3  # +3 for position, pnl, drawdown

    def reset(self, seed=None, options=None):
        super().reset(seed=seed)
        self.step_idx = 0
        self.balance = self.config.initial_balance
        self.position = 0
        self.entry_price = 0.0
        self.total_pnl = 0.0
        self.peak_balance = self.config.initial_balance
        self.trade_count = 0
        self.win_count = 0
        self._done = False
        return self._get_obs(), {}

    def _get_obs(self):
        """Get observation - SAFE version."""
        # Clamp index to valid range
        idx = max(0, min(self.step_idx, self.n_bars - 1))

        # Get market features
        features = self.features[idx].copy()

        # Add state features
        norm_pnl = np.clip(self.total_pnl / self.config.initial_balance, -1.0, 1.0)
        drawdown = self._get_drawdown()

        # Combine
        obs = np.concatenate([
            features,
            np.array([float(self.position), norm_pnl, drawdown], dtype=np.float32)
        ]).astype(np.float32)

        # SAFETY: Replace any NaN/Inf
        obs = np.nan_to_num(obs, nan=0.0, posinf=0.0, neginf=0.0)

        # Clip to observation space bounds
        obs = np.clip(obs, -10.0, 10.0)

        return obs

    def _get_drawdown(self):
        """Calculate current drawdown."""
        current_value = self.balance + self._unrealized_pnl()
        if current_value >= self.peak_balance:
            self.peak_balance = current_value
            return 0.0
        dd = (self.peak_balance - current_value) / (self.peak_balance + 1e-8)
        return float(np.clip(dd, 0.0, 1.0))

    def _unrealized_pnl(self):
        """Calculate unrealized PnL."""
        if self.position == 0:
            return 0.0
        idx = max(0, min(self.step_idx, self.n_bars - 1))
        price = self.prices[idx]
        if self.position > 0:
            return (price - self.entry_price) * self.config.max_position
        else:
            return (self.entry_price - price) * self.config.max_position

    def _get_cost(self):
        """Get transaction cost."""
        idx = max(0, min(self.step_idx, self.n_bars - 1))
        price = self.prices[idx]
        cost = (self.config.spread + self.config.commission) * price
        if idx < len(self.news) and self.news[idx] > 0:
            cost *= self.config.slippage_news_mult
        return cost

    def step(self, action):
        """Execute one step - GUARANTEED to terminate."""
        # ===== CHECK DONE CONDITIONS FIRST =====

        # Condition 1: Already done
        if self._done:
            return self._get_obs(), 0.0, True, False, self._get_info()

        # Condition 2: Reached end of data
        if self.step_idx >= self.n_bars - 1:
            self._done = True
            if self.position != 0:
                self._close_position()
            return self._get_obs(), 0.0, True, False, self._get_info()

        # Condition 3: Reached max_steps
        if self.step_idx >= self.max_steps:
            self._done = True
            if self.position != 0:
                self._close_position()
            return self._get_obs(), 0.0, True, False, self._get_info()

        # ===== EXECUTE STEP =====
        idx = self.step_idx
        price = self.prices[idx]
        pnl = 0.0

        # Check max drawdown
        if self._get_drawdown() >= self.config.max_total_drawdown:
            if self.position != 0:
                pnl = self._close_position()
            self._done = True
            return self._get_obs(), -1.0, True, False, self._get_info()

        # Check stop loss / take profit
        if self.position != 0:
            pnl_pct = self._unrealized_pnl() / self.config.initial_balance
            if pnl_pct <= -self.config.stop_loss_pct or pnl_pct >= self.config.take_profit_pct:
                pnl = self._close_position()

        # Execute action
        if action == 1 and self.position <= 0:  # Buy
            if self.position < 0:
                pnl += self._close_position()
            self._open_position(1, price)
        elif action == 2 and self.position >= 0:  # Sell
            if self.position > 0:
                pnl += self._close_position()
            self._open_position(-1, price)

        # Move forward
        self.step_idx += 1

        # Calculate reward
        reward = float(pnl / self.config.initial_balance)
        reward = np.clip(reward, -1.0, 1.0)  # Clip extreme rewards

        # Check if done after step
        done = self.step_idx >= self.n_bars - 1 or self.step_idx >= self.max_steps

        # Close position at end
        if done and self.position != 0:
            final_pnl = self._close_position()
            reward += float(final_pnl / self.config.initial_balance)
            reward = np.clip(reward, -1.0, 1.0)

        self._done = done

        return self._get_obs(), reward, done, False, self._get_info()

    def _open_position(self, direction, price):
        """Open a position."""
        self.balance -= self._get_cost()
        self.position = direction
        self.entry_price = price

    def _close_position(self):
        """Close position and return PnL."""
        if self.position == 0:
            return 0.0

        idx = max(0, min(self.step_idx, self.n_bars - 1))
        price = self.prices[idx]
        cost = self._get_cost()

        if self.position > 0:
            pnl = (price - self.entry_price) * self.config.max_position - cost
        else:
            pnl = (self.entry_price - price) * self.config.max_position - cost

        self.total_pnl += pnl
        self.balance += pnl
        self.trade_count += 1
        if pnl > 0:
            self.win_count += 1

        self.position = 0
        self.entry_price = 0.0

        return pnl

    def _get_info(self):
        """Get info dict."""
        return {
            'total_pnl': self.total_pnl,
            'trade_count': self.trade_count,
            'win_rate': self.win_count / max(1, self.trade_count),
            'drawdown': self._get_drawdown(),
            'step': self.step_idx,
        }

