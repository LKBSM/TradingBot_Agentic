# Banc d'essai fournisseurs — cles API (une par fournisseur).
# Cle absente = fournisseur "non teste" (jamais simule).
# Ce fichier est un exemple : copier en tools/data-benchmark/.env (gitignore)
# ou laisser le runner lire le .env racine du repo.

# --- Reference du banc (etalon des comparaisons de meches) ---
TWELVE_DATA_API_KEY=

# --- Gratuits / compte gratuit ---
OANDA_API_TOKEN=            # compte practice gratuit -> jeton API v20
OANDA_ENV=practice          # practice | live
TIINGO_API_KEY=             # free tier 1000 req/j (run lent: 50 req/h)
FCSAPI_API_KEY=             # free 500 credits
FINAZON_API_KEY=            # essai gratuit
ITICK_API_KEY=              # free tier (adaptateur non valide, a ajuster au 1er run)
ALLTICK_API_KEY=            # demo 10 symboles (adaptateur non valide)
MASSIVE_API_KEY=            # ex-Polygon.io, 5 req/min free (alias POLYGON_API_KEY)

# --- Payants / essai court (a fournir si tu veux les tester) ---
EODHD_API_KEY=              # plan 29.99$/mois requis pour forex+intraday
FMP_API_KEY=                # plan Starter 22$/mois requis
TRADERMADE_API_KEY=         # 1000 req/mois gratuit = sous-ensemble seulement
FINAGE_API_KEY=             # essai 3 jours
FINNHUB_API_KEY=            # candles = premium only
ALPHAVANTAGE_API_KEY=       # intraday = premium only
