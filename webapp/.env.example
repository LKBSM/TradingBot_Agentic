# ─────────────────────────────────────────────────────────────────────────────
# MIA Markets — webapp (Next.js 15) environment template
# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base (FastAPI — Chantiers 1-4).
# The `/api/*` rewrite in next.config.js proxies every API call (including the
# chatbot `POST /api/chatbot/message`) to `${NEXT_PUBLIC_API_BASE}/api/*`.
# Defaults to http://localhost:8000 when unset (see next.config.js rewrites()).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# In production (Vercel front + FastAPI on Fly.io), point to the backend host:
# NEXT_PUBLIC_API_BASE=https://api.mia.markets

# ─────────────────────────────────────────────────────────────────────────────
# NOTE — Chantier 5.A decommission:
# The webapp no longer calls Anthropic directly. There is NO ANTHROPIC_API_KEY
# on the frontend anymore — the Anthropic SDK was removed and the only Anthropic
# key lives server-side on the FastAPI backend (where the 3 niveau-1.5 defence
# layers run). Do NOT reintroduce an Anthropic key here.
# ─────────────────────────────────────────────────────────────────────────────
