        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Signal PnL Distribution (pips)",
      "type": "histogram",
      "targets": [
        {
          "expr": "trading_signal_pnl_pips_bucket",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
