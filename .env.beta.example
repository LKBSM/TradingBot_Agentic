# =============================================================================
# MIA Markets — Private BETA environment (docker-compose.beta.yml)
#
#   cp .env.beta.example .env      # then fill the SECRETS below
#   docker compose -f docker-compose.beta.yml up -d --build
#
# This file is a TEMPLATE — it is safe to commit. The real `.env` it produces
# holds secrets and is git-ignored + docker-ignored. NEVER commit `.env`.
# =============================================================================

# ── Sessions & owner (REQUIRED — no defaults; compose refuses to start without)
# Generate a strong random SESSION_SECRET, e.g.:  openssl rand -hex 32
SESSION_SECRET=change-me-to-a-64-char-random-hex
# Local http (no TLS) → keep 0 so the session cookie is sent. Behind HTTPS: 1.
SESSION_COOKIE_SECURE=0
# The single operator account, seeded (hashed) at first boot. Distinct from
# the tester accounts created by scripts/seed_testers.py.
OWNER_USERNAME=owner
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me-strong-owner-password

# ── Beta lockdown (already forced ON in compose; these are optional knobs) ───
# Restrict access to specific roles ("tester,owner"). Empty = any active account.
BETA_ALLOWED_ROLES=

# ── Product engine (fill to make readings/chat fully live) ───────────────────
# Without these the app still boots and auth/lockdown work, but market-reading /
# chat endpoints degrade to 503 (no data source / no LLM).
ANTHROPIC_API_KEY=
TWELVE_DATA_API_KEY=
BOOTSTRAP_ENABLED=true
SCHEDULER_ENABLED=true
CHATBOT_ENABLED=true
NEWS_PIPELINE_ENABLED=true
LIVE_TICK_ENABLED=false
VOL_MODE=har
SYMBOLS=XAUUSD

# ── Networking / misc ────────────────────────────────────────────────────────
FRONTEND_PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
LOG_FORMAT=json
